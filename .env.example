DATABASE_URL=postgresql://admin:admin123@postgres:5432/meubanco
REDIS_URL=redis://redis:6379

# S3/AWS em producao:
# - Para AWS S3 nativo, deixe S3_ENDPOINT_URL vazio.
# - Para MinIO/local, use S3_ENDPOINT_URL=http://minio:9002.
S3_ENDPOINT_URL=http://minio:9002
S3_BUCKET_NAME=
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin

K8S_CONTROLPANEL_HOST=controlpanel
K8S_CONTROLPANEL_PORT=8000
K8S_WHATSAPP_HOST=whatsapp_service
K8S_WHATSAPP_PORT=8000

CHECK_INTERVAL_STANDARD=30

# Check sintetico opcional. Padrao seguro: nao gera mensagem nem custo.
ENABLE_COSTLY_CHECKS=false
CHECK_INTERVAL_COSTLY=14400
WHATSAPP_LOGIC_URL=http://whatsapp_service:8000/direct-message

# Redis Streams monitorados no fluxo do Edite.
STREAMS_GROUPS=queue_questions:agents_group,queue_questions:db_group,queue_responses:whatsapp_group,queue_responses:db_responses_group,queue_responses_dlq:ops_group,queue_consent:db_consent_group

# A fila pode ter passagem momentanea. O problema operacional e acumulo ou mensagem velha.
QUEUE_STALE_THRESHOLD_MS=120000
QUEUE_LAG_THRESHOLD=50
QUEUE_PENDING_THRESHOLD=200
QUEUE_MAX_PENDING_INSPECT=200
